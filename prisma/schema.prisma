generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Customer {
  id                String   @id @default(cuid())
  shopifyCustomerId String   @unique
  email             String
  name              String?
  createdAt         DateTime @default(now())

  wallet Wallet?
  orders MenuOrder[]

  savedCollections SavedCollection[]

  sellingPlanOrders SellingPlanOrder[]
}

model Wallet {
  id      String @id @default(cuid())
  balance Float  @default(0)

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String   @unique

  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String
  description String
  createdAt   DateTime @default(now())

  wallet   Wallet @relation(fields: [walletId], references: [id])
  walletId String
}

model MenuOrder {
  id        String   @id @default(cuid())
  itemName  String
  price     Float
  createdAt DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String
}

  model SellingPlanOrder {
    id String @id @default(cuid())
    
    customer   Customer @relation(fields: [customerId], references: [id])
    customerId String

    shopifyCustomerId String
    email String?
    title           String
    quantity        Int
    pax Int @default(1)
    sellingPlanId   String
    sellingPlanName String?
    totalValue      Float

    createdAt DateTime @default(now())
}

model SavedCollection {
  id String @id @default(cuid())

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  collectionId    String
  collectionTitle String?
  products        Json?   //  ADD THIS
  persons     Int @default(2)
  createdAt       DateTime @default(now())

  @@unique([customerId, collectionId])
}

model ProcessedWebhook { 
  id String @id @default(cuid())
  webhookId String @unique
  createdAt DateTime @default(now()) 
  }
